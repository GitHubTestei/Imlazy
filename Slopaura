local function normalizeName(name)
    return name:lower():gsub("%s+", "")
end

local function playerMatchesQuery(player, query)
    local q = normalizeName(query)
    return normalizeName(player.DisplayName):find(q, 1, true) ~= nil
        or normalizeName(player.Name):find(q, 1, true) ~= nil
end

local function isInList(player, list)
    for _, query in ipairs(list) do
        if playerMatchesQuery(player, query) then return true end
    end
    return false
end

local function parseList(text)
    local result = {}
    for word in text:gmatch("%S+") do table.insert(result, word) end
    return result
end

local function removeTagFor(player)
    if tagBillboards[player.Name] then
        pcall(function() tagBillboards[player.Name]:Destroy() end)
        tagBillboards[player.Name] = nil
    end
    if tagConnections[player.Name] then
        tagConnections[player.Name]:Disconnect()
        tagConnections[player.Name] = nil
    end
end

local function applyTagTo(player, label, color)
    removeTagFor(player)
    local function makeTag(char)
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then hrp = char:WaitForChild("HumanoidRootPart", 5) end
        if not hrp then return end
        local old = hrp:FindFirstChild("PlayerTag")
        if old then old:Destroy() end
        local bb = Instance.new("BillboardGui")
        bb.Name = "PlayerTag"
        bb.Size = UDim2.new(0, 120, 0, 40)
        bb.StudsOffset = Vector3.new(0, 4, 0)
        bb.AlwaysOnTop = true
        bb.Adornee = hrp
        bb.Parent = hrp
        local lbl = Instance.new("TextLabel", bb)
        lbl.Size = UDim2.new(1, 0, 1, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text = label
        lbl.TextColor3 = color
        lbl.Font = Enum.Font.GothamBold
        lbl.TextSize = 28
        lbl.TextStrokeTransparency = 0
        lbl.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        tagBillboards[player.Name] = bb
    end
    if player.Character then makeTag(player.Character) end
    tagConnections[player.Name] = player.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        makeTag(char)
    end)
end

local function refreshTags()
    for _, player in ipairs(Players:GetPlayers()) do
        if player == me then continue end
        removeTagFor(player)
        if friendTagEnabled and isInList(player, friendsList) then
            applyTagTo(player, "bestie", Color3.fromRGB(255, 182, 193))
        elseif targetTagEnabled and isInList(player, targetsList) then
            applyTagTo(player, "baddie", Color3.fromRGB(255, 255, 255))
        end
    end
end

local function getNearest()
    local nearest, shortest = nil, math.huge
    local myRoot = me.Character and me.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= me and p.Character then
            if isInList(p, friendsList) then continue end
            if #targetsList > 0 and not isInList(p, targetsList) then continue end
            local root = p.Character:FindFirstChild("HumanoidRootPart")
            if root then
                local dist = (myRoot.Position - root.Position).Magnitude
                if dist < shortest then nearest, shortest = p, dist end
            end
        end
    end
    return nearest
end

local function hit()
    local target = getNearest()
    if target and target.Character then
        game:GetService("ReplicatedStorage").Packages.Knit.Services.CombatService.RF.Hit:InvokeServer(target.Character.Humanoid)
    end
end

local _arc_targetCFrame = CFrame.new(-502.844818, 10.1868954, -65.4427567, 0.560596228, 2.67291544e-09, -0.828089297, -2.95736768e-08, 1, -1.67928462e-08, 0.828089297, 3.39036497e-08, 0.560596228)
local _arc_safeCFrame = _arc_targetCFrame + Vector3.new(0, 1, 0)
local ArcDefaultDelay = 0.1
local ArcGrabDelay = 3.5
local _arc_connection, _arc_platStandConn = nil, nil
local _arc_originalCFrame = nil
local _arc_hasCleanedThisRagdoll = false
local _arc_returnTask = nil
local _arc_inReturnWindow = false
local _arc_wasGrabbed = false
local _arc_platform = nil
local _arc_platformStandConn = nil

local function _arc_resetState()
    _arc_originalCFrame = nil
    _arc_returnTask = nil
    _arc_hasCleanedThisRagdoll = false
    _arc_inReturnWindow = false
    _arc_wasGrabbed = false
end

local function _arc_removePlatform()
    if _arc_platformStandConn then _arc_platformStandConn:Disconnect() _arc_platformStandConn = nil end
    if _arc_platform then pcall(function() _arc_platform:Destroy() end) _arc_platform = nil end
end

local function _arc_spawnPlatform(position)
    _arc_removePlatform()
    local W, H, D, T = 16, 10, 16, 1
    local floorY = position.Y - 3.5
    local floorCY = floorY - T/2
    local ceilCY = floorY + H + T/2
    local innerCY = floorY + H/2
    local model = Instance.new("Model")
    model.Name = "ARC_SafeBox"
    model.Parent = workspace
    _arc_platform = model
    local function makePart(size, cf)
        local p = Instance.new("Part")
        p.Size = size p.CFrame = cf p.Anchored = true p.CanCollide = true
        p.Locked = true p.Material = Enum.Material.SmoothPlastic
        p.BrickColor = BrickColor.new("Medium stone grey") p.Transparency = 0.4
        p.Parent = model return p
    end
    local cx, cz = position.X, position.Z
    makePart(Vector3.new(W,T,D), CFrame.new(cx,floorCY,cz))
    makePart(Vector3.new(W,T,D), CFrame.new(cx,ceilCY,cz))
    makePart(Vector3.new(W,H+T*2,T), CFrame.new(cx,innerCY,cz+D/2+T/2))
    makePart(Vector3.new(W,H+T*2,T), CFrame.new(cx,innerCY,cz-D/2-T/2))
    makePart(Vector3.new(T,H+T*2,D), CFrame.new(cx-W/2-T/2,innerCY,cz))
    makePart(Vector3.new(T,H+T*2,D), CFrame.new(cx+W/2+T/2,innerCY,cz))
    local platformTopY = floorY
    _arc_platformStandConn = RS.Heartbeat:Connect(function()
        if not _arc_platform or not _arc_platform.Parent then _arc_removePlatform() return end
        local hrp = me.Character and me.Character:FindFirstChild("HumanoidRootPart")
        if hrp and hrp.Parent and hrp.Position.Y < platformTopY then
            hrp.CFrame = CFrame.new(cx, platformTopY+3.5, cz)
            hrp.AssemblyLinearVelocity = Vector3.new(0,0,0)
        end
    end)
end

local function _arc_countDisabledMotors(char)
    if not char then return 0, 0 end
    local total, disabled = 0, 0
    for _, obj in ipairs(char:GetDescendants()) do
        if obj:IsA("Motor6D") then total += 1 if not obj.Enabled then disabled += 1 end end
    end
    return total, disabled
end

local function _arc_forceEndRagdoll(char)
    if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if humanoid then
        for _, state in ipairs({Enum.HumanoidStateType.Ragdoll, Enum.HumanoidStateType.Physics, Enum.HumanoidStateType.FallingDown, Enum.HumanoidStateType.PlatformStanding}) do
            pcall(function() humanoid:SetStateEnabled(state, false) end)
        end
        humanoid.PlatformStand = false
        humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
    end
    for _, n in ipairs({"RagdollJoints","NoCollisions","Local Ragdoll"}) do
        local obj = char:FindFirstChild(n) if obj then obj:Destroy() end
    end
    for _, obj in ipairs(char:GetDescendants()) do
        if obj:IsA("Motor6D") then obj.Enabled = true
        elseif (obj:IsA("BaseConstraint") or obj:IsA("Attachment")) and obj.Name:lower():find("ragdoll") then obj:Destroy() end
    end
end

local function _arc_doReturn(hrp, savedCFrame)
    if hrp and hrp.Parent then
        local safePos = _arc_safeCFrame.Position
        _arc_spawnPlatform(safePos)
        hrp.CFrame = CFrame.new(safePos.X, safePos.Y, safePos.Z)
        hrp.AssemblyLinearVelocity = Vector3.new(0,0,0)
    end
    _arc_returnTask = task.delay(ArcGrabDelay, function()
        _arc_removePlatform()
        if hrp and hrp.Parent and savedCFrame then
            hrp.CFrame = savedCFrame
            task.delay(0.05, function()
                if hrp and hrp.Parent then hrp.AssemblyLinearVelocity = Vector3.new(0,-1,0) end
            end)
        end
        _arc_resetState()
    end)
end

local function _arc_onCharacterAdded(char)
    local hrp = char:WaitForChild("HumanoidRootPart", 10)
    local hum = char:WaitForChild("Humanoid", 10)
    if not hrp or not hum then return end
    if _arc_connection then _arc_connection:Disconnect() _arc_connection = nil end
    if _arc_platStandConn then _arc_platStandConn:Disconnect() _arc_platStandConn = nil end
    _arc_resetState()
    if _arc_returnTask then task.cancel(_arc_returnTask) _arc_returnTask = nil end
    task.wait(2.5)
    if not AntiRagEnabled and not AntiGrabRagEnabled then return end
    _arc_connection = RS.Heartbeat:Connect(function()
        if not AntiRagEnabled then return end
        if not char.Parent or not hrp.Parent then
            if _arc_connection then _arc_connection:Disconnect() _arc_connection = nil end
            return
        end
        if _arc_inReturnWindow then return end
        local total, disabled = _arc_countDisabledMotors(char)
        local isRagdolled = total >= 12 and (disabled/total) >= 0.9
        if isRagdolled then
            if not _arc_originalCFrame then _arc_originalCFrame = hrp.CFrame end
            if not _arc_hasCleanedThisRagdoll then
                hrp.CFrame = _arc_safeCFrame
                _arc_forceEndRagdoll(char)
                _arc_hasCleanedThisRagdoll = true
            end
        else
            if _arc_originalCFrame and not _arc_returnTask then
                _arc_inReturnWindow = true
                local savedCFrame = _arc_originalCFrame
                _arc_returnTask = task.delay(ArcDefaultDelay, function()
                    if hrp and hrp.Parent and savedCFrame then
                        hrp.CFrame = savedCFrame
                        task.delay(0.05, function()
                            if hrp and hrp.Parent then hrp.AssemblyLinearVelocity = Vector3.new(0,-1,0) end
                        end)
                    end
                    _arc_resetState()
                end)
            end
            _arc_hasCleanedThisRagdoll = false
        end
    end)
end

local function startARC()
    local char = me.Character
    if char then task.spawn(_arc_onCharacterAdded, char) end
end

local function stopARC()
    if not AntiRagEnabled and not AntiGrabRagEnabled then
        if _arc_connection then _arc_connection:Disconnect() _arc_connection = nil end
        if _arc_platStandConn then _arc_platStandConn:Disconnect() _arc_platStandConn = nil end
        _arc_removePlatform()
    end
end

local function setupAntiGrab(char)
    local hum = char:WaitForChild("Humanoid", 10)
    local hrp = char:WaitForChild("HumanoidRootPart", 10)
    if not hum or not hrp then return end
    hum:GetPropertyChangedSignal("PlatformStand"):Connect(function()
        if not antiGrabEnabled then return end
        if hum.PlatformStand then
            local originalPos = hrp.Position
            -- fully reset ARC state so steady 1 works clean after this
            _arc_resetState()
            game:GetService("ReplicatedStorage").EventInviteSystem.EventTeleportEvent:FireServer()
            task.delay(0.2, function()
                local currentHrp = me.Character and me.Character:FindFirstChild("HumanoidRootPart")
                if currentHrp then currentHrp.CFrame = CFrame.new(originalPos) end
                -- reset again after teleport back so nothing is left dirty
                _arc_resetState()
            end)
        end
    end)
end

local function setupDeathTp(char)
    local hrp = char:WaitForChild("HumanoidRootPart", 10)
    local hum = char:WaitForChild("Humanoid", 10)
    if not hrp or not hum then return end
    hum.Died:Connect(function() if deathTpEnabled then lastDeathPos = hrp.CFrame end end)
end

me.CharacterAdded:Connect(function(newChar)
    task.spawn(_arc_onCharacterAdded, newChar)
    task.spawn(setupDeathTp, newChar)
    task.spawn(setupAntiGrab, newChar)
    if deathTpEnabled and lastDeathPos then
        task.wait(0.3)
        local hrp = newChar:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.CFrame = lastDeathPos end
    end
end)

if me.Character then
    task.spawn(setupDeathTp, me.Character)
    task.spawn(setupAntiGrab, me.Character)
end

