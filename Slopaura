toggle.MouseButton1Click:Connect(function()
    frame.Visible = not frame.Visible
end)

actionBtn.MouseButton1Click:Connect(function()
    running = not running
    if running then
        actionBtn.Text = "passive 😖"
        actionBtn.BackgroundColor3 = Color3.fromRGB(210, 210, 210)
        conn = RS.Heartbeat:Connect(hit)
    else
        actionBtn.Text = "aggresive 😣"
        actionBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        if conn then conn:Disconnect() conn = nil end
    end
end)

local dragging = false
local dragStart, frameStart

local function onInputBegan(i)
    if frame.Visible and i.UserInputType == Enum.UserInputType.Touch then
        local pos = i.Position
        local ap = frame.AbsolutePosition
        local as = frame.AbsoluteSize
        if pos.X >= ap.X and pos.X <= ap.X + as.X and pos.Y >= ap.Y and pos.Y <= ap.Y + as.Y then
            dragging = true
            dragStart = pos
            frameStart = ap
        end
    end
end

local function onInputChanged(i)
    if dragging and i.UserInputType == Enum.UserInputType.Touch then
        local delta = i.Position - dragStart
        frame.Position = UDim2.new(0, frameStart.X + delta.X, 0, frameStart.Y + delta.Y)
    end
end

local function onInputEnded(i)
    if i.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end

game:GetService("UserInputService").InputBegan:Connect(onInputBegan)
game:GetService("UserInputService").InputChanged:Connect(onInputChanged)
game:GetService("UserInputService").InputEnded:Connect(onInputEnded)
